{
  "name": "todo-hono-postmark",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "hono": "^4.8.2",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260317.1",
      "better-auth": "^1.5.5",
      "alchemy": "^0.82.1",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1",
      "jsdom": "^26.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo -F @todo-hono-postmark/infra -F @todo-hono-postmark/db dev db:studio",
    "deploy:dev": "bun run --filter @todo-hono-postmark/infra deploy:dev",
    "deploy:staging": "bun run --filter @todo-hono-postmark/infra deploy:staging",
    "deploy:prod": "bun run --filter @todo-hono-postmark/infra deploy:prod",
    "destroy:dev": "bun run --filter @todo-hono-postmark/infra destroy:dev",
    "destroy:staging": "bun run --filter @todo-hono-postmark/infra destroy:staging",
    "destroy:prod": "bun run --filter @todo-hono-postmark/infra destroy:prod",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:dev-up": "docker compose up -d",
    "db:dev-down": "docker compose down",
    "db:push": "turbo -F @todo-hono-postmark/db db:push",
    "db:studio": "turbo -F @todo-hono-postmark/db db:studio",
    "db:generate": "turbo -F @todo-hono-postmark/db db:generate",
    "db:migrate": "turbo -F @todo-hono-postmark/db db:migrate",
    "open-auth-docs": "open-cli http://localhost:3000/api/auth/reference",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@todo-hono-postmark/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@todo-hono-postmark/config": "workspace:*",
    "@types/node": "catalog:",
    "open-cli": "^9.0.0",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.34.0",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
